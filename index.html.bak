<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>ShopRef</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Barlow:wght@400;600&family=Barlow+Condensed:wght@700;900&display=swap" rel="stylesheet">
<style>
:root {
  --bg:#0d0f0e;--surface:#161a18;--border:#2a3330;
  --accent:#00e87a;--accent-dim:#00b85f;--warn:#f5a623;
  --red:#e8453c;--text:#e8ede9;--muted:#6b7d74;
  --mono:'Share Tech Mono',monospace;
  --sans:'Barlow',sans-serif;
  --cond:'Barlow Condensed',sans-serif;
}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--bg);color:var(--text);font-family:var(--sans);min-height:100vh;padding:16px}
.app{max-width:640px;margin:0 auto}
.header{display:flex;align-items:baseline;gap:10px;margin-bottom:20px;border-bottom:1px solid var(--border);padding-bottom:14px}
.logo{font-family:var(--cond);font-size:28px;font-weight:900;color:var(--accent);letter-spacing:2px;text-transform:uppercase}
.logo span{color:var(--muted);font-weight:400;font-size:12px;letter-spacing:1px;margin-left:4px}
.session-strip{display:flex;gap:8px;margin-bottom:12px;align-items:center}
.session-strip input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:12px;padding:7px 10px;border-radius:5px;outline:none}
.session-strip input::placeholder{color:var(--muted)}
.session-strip input:focus{border-color:var(--accent)}
.vehicle-bar{display:flex;gap:8px;margin-bottom:14px}
.vehicle-bar select{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:var(--mono);font-size:12px;padding:8px;border-radius:5px;outline:none;cursor:pointer}
.vehicle-bar select:focus{border-color:var(--accent)}
.vehicle-pill{display:none;align-items:center;gap:8px;background:var(--surface);border:1px solid var(--accent);border-radius:6px;padding:7px 12px;font-family:var(--mono);font-size:12px;color:var(--accent);margin-bottom:14px}
.vehicle-pill .clear{cursor:pointer;color:var(--muted);font-size:16px;line-height:1;margin-left:4px}
.vehicle-pill .clear:hover{color:var(--red)}
.query-row{display:flex;gap:8px;margin-bottom:12px}
.query-input{flex:1;background:var(--surface);border:1px solid var(--border);color:var(--text);font-family:var(--sans);font-size:15px;padding:12px 14px;border-radius:6px;outline:none;transition:border-color 0.15s}
.query-input::placeholder{color:var(--muted)}
.query-input:focus{border-color:var(--accent)}
.btn-mic{width:48px;height:48px;background:var(--surface);border:1px solid var(--border);border-radius:6px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--text);transition:border-color 0.15s,background 0.15s}
.btn-mic:hover{border-color:var(--accent)}
.btn-mic.listening{border-color:var(--red);background:rgba(232,69,60,0.12);animation:pulse-border 1s ease-in-out infinite}
@keyframes pulse-border{0%,100%{box-shadow:0 0 0 0 rgba(232,69,60,0.4)}50%{box-shadow:0 0 0 6px rgba(232,69,60,0)}}
.btn-go{padding:0 20px;height:48px;background:var(--accent);border:none;border-radius:6px;color:#000;font-family:var(--cond);font-size:16px;font-weight:700;letter-spacing:1px;text-transform:uppercase;cursor:pointer;transition:background 0.15s;flex-shrink:0}
.btn-go:hover{background:var(--accent-dim)}
.btn-go:disabled{background:var(--border);color:var(--muted);cursor:not-allowed}
.status-bar{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:10px;min-height:14px}
.status-bar.listening{color:var(--red)}
.status-bar.thinking{color:var(--warn)}
.status-bar.done{color:var(--accent)}
.result-card{background:var(--surface);border:1px solid var(--border);border-radius:8px;overflow:hidden;display:none;margin-bottom:14px}
.result-card.show{display:block}
.result-header{padding:9px 14px;border-bottom:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;gap:8px}
.result-query{font-family:var(--mono);font-size:11px;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.verify-badge{font-family:var(--mono);font-size:10px;padding:2px 7px;border-radius:3px;border:1px solid var(--warn);color:var(--warn);white-space:nowrap;flex-shrink:0}
.result-body{padding:16px 14px}
.answer-main{font-family:var(--cond);font-size:44px;font-weight:900;color:var(--accent);line-height:1;margin-bottom:10px;letter-spacing:1px}
.answer-detail{font-size:14px;color:var(--text);line-height:1.6;opacity:0.85}
.answer-detail strong{color:var(--accent);font-weight:600}
.result-footer{padding:8px 14px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.confidence{font-family:var(--mono);font-size:11px;color:var(--muted)}
.confidence.high{color:var(--accent)}
.confidence.med{color:var(--warn)}
.confidence.low{color:var(--red)}
.feedback-row{display:none;gap:8px;padding:8px 14px;border-top:1px solid var(--border);align-items:center}
.feedback-row.show{display:flex}
.feedback-label{font-family:var(--mono);font-size:11px;color:var(--muted);flex-shrink:0}
.btn-feedback{padding:4px 12px;border-radius:4px;border:1px solid var(--border);background:none;font-family:var(--mono);font-size:11px;cursor:pointer;color:var(--muted);transition:border-color 0.1s,color 0.1s,background 0.1s}
.btn-feedback:hover{border-color:var(--accent);color:var(--accent)}
.btn-feedback.selected-y{border-color:var(--accent);color:var(--accent);background:rgba(0,232,122,0.08)}
.btn-feedback.selected-n{border-color:var(--red);color:var(--red);background:rgba(232,69,60,0.08)}
.btn-feedback.selected-q{border-color:var(--warn);color:var(--warn);background:rgba(245,166,35,0.08)}
.history{margin-top:4px}
.history-label{font-family:var(--mono);font-size:10px;color:var(--muted);letter-spacing:1px;text-transform:uppercase;margin-bottom:6px}
.history-item{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid var(--border);cursor:pointer}
.history-item:last-child{border-bottom:none}
.history-item:hover .h-query{color:var(--accent)}
.h-query{font-size:13px;color:var(--text);opacity:0.7;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;transition:color 0.1s}
.h-answer{font-family:var(--mono);font-size:12px;color:var(--accent);white-space:nowrap;flex-shrink:0;max-width:140px;overflow:hidden;text-overflow:ellipsis}
.h-badge{font-family:var(--mono);font-size:10px;padding:1px 5px;border-radius:3px;flex-shrink:0}
.h-badge.y{background:rgba(0,232,122,0.12);color:var(--accent)}
.h-badge.n{background:rgba(232,69,60,0.12);color:var(--red)}
.h-badge.q{background:rgba(245,166,35,0.12);color:var(--warn)}
.thinking-dots span{animation:blink 1.2s infinite;opacity:0}
.thinking-dots span:nth-child(2){animation-delay:0.2s}
.thinking-dots span:nth-child(3){animation-delay:0.4s}
@keyframes blink{0%,100%{opacity:0}50%{opacity:1}}
.no-voice-msg{font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:10px;display:none}
@media(max-width:480px){.answer-main{font-size:36px}.btn-go{padding:0 14px;font-size:14px}.vehicle-bar{flex-wrap:wrap}.vehicle-bar select{min-width:calc(50% - 4px)}}
</style>
</head>
<body>
<div class="app">
<div class="header">
  <div class="logo">ShopRef <span>PHASE 1 — FIELD TEST</span></div>
</div>
<div class="session-strip">
  <input type="text" id="input-session" placeholder="Session #" style="max-width:110px"/>
  <input type="text" id="input-tech" placeholder="Tech name"/>
</div>
<div class="session-strip">
  <input type="text" id="input-vin" placeholder="VIN (optional)" maxlength="17" style="text-transform:uppercase;letter-spacing:1px;" oninput="this.value=this.value.toUpperCase()"/>
</div><div class="vehicle-bar" id="vehicle-bar">
  <select id="sel-year"><option value="">Year</option></select>
  <select id="sel-make" disabled><option value="">Make</option></select>
  <select id="sel-model" disabled><option value="">Model</option></select>
  <button class="btn-go" id="btn-lock" onclick="lockVehicle()" disabled style="height:36px;font-size:13px;padding:0 14px">SET</button>
</div>
<div class="vehicle-pill" id="vehicle-pill">
  <span id="vehicle-label"></span>
  <span class="clear" onclick="clearVehicle()" title="Change">✕</span>
</div>
<div class="query-row">
  <input class="query-input" id="query-input" placeholder="What spec do you need?" onkeydown="if(event.key==='Enter')submitQuery()"/>
  <button class="btn-mic" id="btn-mic" onclick="toggleMic()" title="Tap to speak">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="9" y="2" width="6" height="13" rx="3"/>
      <path d="M5 10a7 7 0 0014 0M12 19v3M8 22h8"/>
    </svg>
  </button>
  <button class="btn-go" id="btn-go" onclick="submitQuery()">ASK</button>
</div>
<div class="no-voice-msg" id="no-voice-msg">⚠ Voice unavailable — use text</div>
<div class="status-bar" id="status-bar"></div>
<div class="result-card" id="result-card">
  <div class="result-header">
    <div class="result-query" id="result-query"></div>
    <div class="verify-badge">VERIFY OEM</div>
  </div>
  <div class="result-body">
    <div class="answer-main" id="answer-main"></div>
    <div class="answer-detail" id="answer-detail"></div>
  </div>
  <div class="result-footer">
    <div class="confidence" id="confidence-label"></div>
  </div>
  <div class="feedback-row" id="feedback-row">
    <span class="feedback-label">Correct?</span>
    <button class="btn-feedback" id="fb-y" onclick="logFeedback('Y')">Y</button>
    <button class="btn-feedback" id="fb-n" onclick="logFeedback('N')">N</button>
    <button class="btn-feedback" id="fb-q" onclick="logFeedback('?')">?</button>
  </div><div class="result-card" id="correction-card" style="display:none;margin-top:8px;">
  <div style="font-family:var(--mono);font-size:11px;color:var(--muted);margin-bottom:6px;">TECH CORRECTION</div>
  <textarea id="correction-input" placeholder="Enter correct spec from ALLDATA or OEM manual..." style="width:100%;background:var(--surface);border:1px solid var(--border);border-radius:6px;color:var(--text);font-family:var(--mono);font-size:12px;padding:8px;resize:vertical;min-height:60px;outline:none;box-sizing:border-box;"></textarea>
  <button onclick="submitCorrection()" style="margin-top:6px;padding:6px 16px;background:var(--accent);color:#000;font-family:var(--cond);font-size:13px;font-weight:700;border:none;border-radius:4px;cursor:pointer;">SUBMIT CORRECTION</button>
</div></div>
<div id="history-section"

</div>
<div class="history" id="history-section" style="display:none">
  <div class="history-label">Session log</div>
  <div id="history-list"></div>
</div>
</div>
<script>// Auto-increment session counter
function getNextSession() {
  const last = parseInt(localStorage.getItem('shopref_session') || '0');
  return String(last).padStart(3, '0');
}
function incrementSession() {
  const last = parseInt(localStorage.getItem('shopref_session') || '0');
  const next = last + 1;
  localStorage.setItem('shopref_session', next);
  document.getElementById('input-session').value = String(next).padStart(3, '0');
}
const YEARS=Array.from({length:35},(_,i)=>(2024-i).toString());
const MAKES=["Acura","BMW","Chevrolet","Chrysler","Dodge","Ford","GMC","Honda","Hyundai","Jeep","Kia","Mazda","Nissan","RAM","Subaru","Toyota","Volkswagen"];
const MODELS={Honda:["Accord","Civic","CR-V","Fit","Odyssey","Pilot"],Ford:["F-150","F-250","Mustang","Explorer","Focus","Ranger"],Chevrolet:["Silverado","Equinox","Malibu","Tahoe","Colorado","Traverse"],Toyota:["Camry","Corolla","Tacoma","4Runner","RAV4","Tundra"],Nissan:["Altima","Frontier","Maxima","Rogue","Sentra","Titan"],BMW:["3 Series","5 Series","7 Series","X3","X5","M3"],Dodge:["Charger","Challenger","Durango","Ram 1500"],Subaru:["Outback","Forester","Impreza","WRX","Crosstrek"],Mazda:["Mazda3","Mazda6","CX-5","MX-5 Miata","CX-9"],Hyundai:["Elantra","Sonata","Tucson","Santa Fe","Kona"],Kia:["Optima","Sorento","Sportage","Soul","Telluride"],Volkswagen:["Jetta","Passat","Tiguan","Golf","Atlas"],Acura:["TLX","MDX","RDX","ILX"],GMC:["Sierra","Yukon","Canyon","Terrain"],Chrysler:["300","Pacifica"],Jeep:["Wrangler","Cherokee","Grand Cherokee","Gladiator","Compass"],RAM:["1500","2500","3500","ProMaster"]};
let vehicle=null,history=[],recognition=null,listening=false,currentEntry=null;document.getElementById('input-session').value = getNextSession();
document.getElementById('input-session').readOnly = true;
const selYear=document.getElementById('sel-year'),selMake=document.getElementById('sel-make'),selModel=document.getElementById('sel-model'),btnLock=document.getElementById('btn-lock'),vehicleBar=document.getElementById('vehicle-bar'),vehiclePill=document.getElementById('vehicle-pill'),vehicleLabel=document.getElementById('vehicle-label'),queryInput=document.getElementById('query-input'),statusBar=document.getElementById('status-bar'),resultCard=document.getElementById('result-card'),btnMic=document.getElementById('btn-mic'),noVoiceMsg=document.getElementById('no-voice-msg'),feedbackRow=document.getElementById('feedback-row');
YEARS.forEach(y=>selYear.add(new Option(y,y)));
selYear.onchange=()=>{selMake.innerHTML='<option value="">Make</option>';MAKES.forEach(m=>selMake.add(new Option(m,m)));selMake.disabled=!selYear.value;selModel.disabled=true;selModel.innerHTML='<option value="">Model</option>';updateLockBtn()};
selMake.onchange=()=>{selModel.innerHTML='<option value="">Model</option>';(MODELS[selMake.value]||[]).forEach(m=>selModel.add(new Option(m,m)));selModel.disabled=!selMake.value;updateLockBtn()};
selModel.onchange=updateLockBtn;
function updateLockBtn(){btnLock.disabled=!(selYear.value&&selMake.value&&selModel.value)}
function lockVehicle(){vehicle=`${selYear.value} ${selMake.value} ${selModel.value}`;vehicleLabel.textContent=vehicle;vehicleBar.style.display='none';vehiclePill.style.display='flex';queryInput.focus();setStatus('Vehicle set — ask your question','done')}
function clearVehicle(){vehicle=null;vehiclePill.style.display='none';vehicleBar.style.display='flex';selYear.value='';selMake.value='';selModel.value='';selMake.disabled=true;selModel.disabled=true;btnLock.disabled=true;resultCard.classList.remove('show');feedbackRow.classList.remove('show');setStatus('','')}
function setStatus(msg,type){statusBar.innerHTML=msg;statusBar.className='status-bar'+(type?' '+type:'')}
async function submitQuery(){
  const q=queryInput.value.trim();
  if(!q)return;incrementSession();
  if(!vehicle){setStatus('⚠ Set vehicle first','thinking');return}
  const goBtn=document.getElementById('btn-go');
  goBtn.disabled=true;resultCard.classList.remove('show');feedbackRow.classList.remove('show');
  statusBar.innerHTML='Fetching <span class="thinking-dots"><span>.</span><span>.</span><span>.</span></span>';
  statusBar.className='status-bar thinking';
  const prompt=`You are ShopRef, a shop floor reference tool for automotive technicians.\nVehicle: ${vehicle}\nTech asks: "${q}"\n\nRespond ONLY with valid JSON, no markdown:\n{\n  "answer": "The lookup result in as few words as possible",\n  "detail": "1-2 sentences of essential context. Use <strong> tags for key values.",\n  "confidence": "high|medium|low",\n  "confidence_note": "brief reason if medium or low, empty string if high"\n}\nRules: answer = raw lookup result, short. Never diagnose. If uncertain set confidence to low.`;
  try {
  const res = await fetch('/api/log', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      session: document.getElementById('input-session').value.trim() || '',
      tech: document.getElementById('input-tech').value.trim() || '',
      vehicle: vehicle, vin: document.getElementById('input-vin').value.trim() || '',
      query: q
    })
  });
  const data = await res.json();
  if (data.error) { setStatus('⚠ API error', ''); console.error(data.error); goBtn.disabled = false; return; }
  currentEntry = { session: document.getElementById('input-session').value.trim() || '', tech: document.getElementById('input-tech').value.trim() || '', vehicle, query: q, answer: data.answer || '', confidence: data.confidence || '', correct: '', notes: data.confidence_note || '', timestamp: data.timestamp, vin: document.getElementById('input-vin').value.trim() || '' }; document.getElementById('input-tech').value.trim() || '', vehicle, query: q, answer: data.answer || '', confidence: data.confidence || '', correct: '', notes: data.confidence_note || '' };
  showResult(q, data);
  addHistory(q, data);
  setStatus('', 'done');
} catch(e) { setStatus('⚠ API error', ''); console.error(e); }
goBtn.disabled = false;
}
function showResult(query,data){
  document.getElementById('result-query').textContent=`${vehicle} — ${query}`;
  document.getElementById('answer-main').textContent=data.answer||'—';
  document.getElementById('answer-detail').innerHTML=data.detail||'';
  const cl=document.getElementById('confidence-label');
  if(data.confidence==='high'){cl.textContent='● HIGH CONFIDENCE';cl.className='confidence high'}
  else if(data.confidence==='medium'){cl.textContent=`⚠ VERIFY — ${data.confidence_note||'check OEM spec'}`;cl.className='confidence med'}
  else{cl.textContent=`✕ LOW — ${data.confidence_note||'look up OEM'}`;cl.className='confidence low'}
  ['fb-y','fb-n','fb-q'].forEach(id=>document.getElementById(id).className='btn-feedback');
  resultCard.classList.add('show');feedbackRow.classList.add('show');
}
async function logFeedback(correct){
  if(!currentEntry)return;
  document.getElementById('fb-y').className='btn-feedback'+(correct==='Y'?' selected-y':'');
  document.getElementById('fb-n').className='btn-feedback'+(correct==='N'?' selected-n':'');
  document.getElementById('fb-q').className='btn-feedback'+(correct==='?'?' selected-q':'');
  currentEntry.correct=correct;
  const lastItem=document.querySelectorAll('.history-item')[0];
  if(lastItem){const badge=lastItem.querySelector('.h-badge');if(badge){badge.textContent=correct;badge.className=`h-badge ${correct.toLowerCase()}`}if(correct==='N') document.getElementById('correction-card').style.display='block';
else document.getElementById('correction-card').style.display='none';}
  try{await fetch('/api/log',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(currentEntry)})}catch(e){console.error('Log failed:',e)}
}async function submitCorrection(){
  const correction = document.getElementById('correction-input').value.trim();
  if(!correction || !currentEntry) return;
  currentEntry.correction = correction;
  try{ await fetch('/api/log', {method:'POST', headers:{'Content-Type':'application/json'}, body:JSON.stringify({...currentEntry, correction})}); }
  catch(e){ console.error('Correction log failed:',e); }
  document.getElementById('correction-card').style.display='none';
  document.getElementById('correction-input').value='';
  setStatus('✓ Correction logged','done');
}
function addHistory(q,data){
  history.unshift({q,answer:data.answer,conf:data.confidence,correct:''});
  if(history.length>8)history.pop();
  const section=document.getElementById('history-section'),list=document.getElementById('history-list');
  section.style.display='block';
  list.innerHTML=history.map(h=>`<div class="history-item"><div class="h-query">${h.q}</div><div class="h-answer">${h.answer}</div><div class="h-badge ${h.correct?h.correct.toLowerCase():''}">${h.correct||''}</div></div>`).join('');
}
const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
if(!SR){noVoiceMsg.style.display='block';btnMic.style.opacity='0.3';btnMic.disabled=true}
else{
  recognition=new SR();recognition.continuous=false;recognition.interimResults=true;recognition.lang='en-US';
  recognition.onstart=()=>{listening=true;btnMic.classList.add('listening');setStatus('Listening...','listening')};
  recognition.onresult=e=>{const t=Array.from(e.results).map(r=>r[0].transcript).join('');queryInput.value=t;if(e.results[e.results.length-1].isFinal)recognition.stop()};
  recognition.onend=()=>{listening=false;btnMic.classList.remove('listening');setStatus('','');if(queryInput.value.trim())submitQuery()};
  recognition.onerror=e=>{listening=false;btnMic.classList.remove('listening');setStatus(`⚠ Mic: ${e.error}`,'')};
}
function toggleMic(){if(!recognition)return;if(listening)recognition.stop();else recognition.start()}
</script>
</body>
</html>

